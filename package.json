    "firebase": "^12.16.0",
    "lucide-react": "^0.507.0",
    "mammoth": "^1.9.0",
    "motion": "^12.12.1",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.22.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-quill-new": "^3.8.3",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
