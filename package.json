{
  "name": "smart-survey-hub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --port=3000\" \"tsx watch server/index.ts\"",
    "dev:client": "vite --port=3000",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
